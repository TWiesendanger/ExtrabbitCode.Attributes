<ui:FluentWindow
    x:Class="ExtrabbitCode.Inventor.Attributes.UI.Dialog.InfoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="InfoDialog"
    Width="1000"
    Height="520"
    ShowInTaskbar="False"
    FontFamily="{DynamicResource InvFontFamily}"
    FontSize="{DynamicResource InvFontSizeNormal}"
    Background="{DynamicResource InvWindowBackgroundBrush}"
    Foreground="{DynamicResource InvForegroundBrush}"
    mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ExtrabbitCode.Inventor.Attributes;component/Resources/Styles/Theme.Shared.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid  Background="{DynamicResource InvWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Margin="-10,0,0,0"
            Title="Info ExtrabbitCode.Inventor.Attributes"
            CanMaximize="False"
            ShowMaximize="False"
            ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon
                    Source="pack://application:,,,/ExtrabbitCode.Inventor.Attributes;component/Resources/appIcon.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Border
            Grid.Row="2"
            Padding="16"
            Background="{DynamicResource InvPanelBackgroundBrush}"
            BorderBrush="{DynamicResource InvPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource InvCornerRadius}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Image
                    Grid.Column="0"
                    Width="72"
                    Height="72"
                    VerticalAlignment="Top"
                    Source="pack://application:,,,/ExtrabbitCode.Inventor.Attributes;component/Resources/appIcon.png" />

                <StackPanel Grid.Column="2">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="ExtrabbitCode.Inventor.Attributes" />

                    <TextBlock
                        Margin="0,6,0,0"
                        Opacity="0.8"
                        Text="Manage and inspect Autodesk Inventor attributes and attribute sets." />

                    <TextBlock
                        Margin="0,10,0,0"
                        FontWeight="SemiBold"
                        Text="{Binding ProgramVersion, StringFormat=Version: {0}}" />
                </StackPanel>

                <Image
                    Grid.Column="3"
                    Width="250"
                    Height="72"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Source="pack://application:,,,/ExtrabbitCode.Inventor.Attributes;component/Resources/extrabbit.png" />
            </Grid>
        </Border>

        <StackPanel
            Margin="10"
            Grid.Row="4"
            Orientation="Horizontal">
            <ui:Button
                Width="180"
                Margin="0,0,8,0"
                Command="{Binding OpenGitHubCommand}"
                Content="GitHub Repository"
                Icon="{ui:SymbolIcon Open24}" />

            <ui:Button
                Width="150"
                Command="{Binding OpenAutodeskStoreCommand}"
                Content="Autodesk Store"
                Icon="{ui:SymbolIcon Open24}" />
        </StackPanel>

        <Border
            Grid.Row="6"
            Padding="12"
            Background="{DynamicResource InvPanelBackgroundBrush}"
            BorderBrush="{DynamicResource InvPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource InvCornerRadius}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Version History" />

                <TextBox
                    Grid.Row="2"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    Text="{Binding VersionHistory}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <StackPanel
            Margin="10"
            Grid.Row="8"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Width="100"
                Click="CloseButton_OnClick"
                Content="Close"
                IsDefault="True" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>