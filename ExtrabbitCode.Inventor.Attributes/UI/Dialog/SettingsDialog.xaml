<ui:FluentWindow
    x:Class="ExtrabbitCode.Inventor.Attributes.UI.Dialog.SettingsDialog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsDialog">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Image
                    Grid.Column="0"
                    Width="24"
                    Height="24"
                    VerticalAlignment="Center"
                    Source="pack://application:,,,/ExtrabbitCode.Inventor.Attributes;component/Resources/appIcon.png" />

                <TextBlock
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    FontSize="20"
                    FontFamily="Tahoma"
                    FontWeight="SemiBold"
                    Text="Settings" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <StackPanel Grid.Row="2">
                <TextBlock
                    Margin="0,0,0,12"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="General" />

                <CheckBox
                    Margin="0,0,0,10"
                    Content="Show warning when deleting a single attribute"
                    IsChecked="{Binding ShowWarningOnSingleAttributeDelete,
                            Mode=TwoWay}" />

                <CheckBox
                    Margin="0,0,0,10"
                    Content="Show warning when deleting all attributes"
                    IsChecked="{Binding ShowWarningOnDeleteAllAttributes,
                            Mode=TwoWay}" />

                <CheckBox
                    Margin="0,0,0,10"
                    Content="Update attributes automatically when switching documents"
                    IsChecked="{Binding UpdateAttributesOnDocumentSwitch,
                            Mode=TwoWay}" />
            </StackPanel>
        </Grid>

        <StackPanel
            Grid.Row="3"
            Margin="0,16,0,0"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Margin="0,0,8,0"
                Click="OkButton_OnClick"
                Content="OK"
                IsDefault="True" />
            <Button
                Width="100"
                Click="CancelButton_OnClick"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>