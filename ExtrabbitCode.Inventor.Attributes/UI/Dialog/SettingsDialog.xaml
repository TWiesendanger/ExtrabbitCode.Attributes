<ui:FluentWindow
    x:Class="ExtrabbitCode.Inventor.Attributes.UI.Dialog.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Settings"
    Width="900"
    Height="650"
    MinWidth="800"
    MinHeight="500"
    FontFamily="{DynamicResource InvFontFamily}"
    FontSize="{DynamicResource InvFontSizeNormal}"
    Background="{DynamicResource InvWindowBackgroundBrush}"
    Foreground="{DynamicResource InvForegroundBrush}"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ExtrabbitCode.Inventor.Attributes;component/Resources/Styles/Theme.Shared.xaml" />
                <ResourceDictionary Source="/ExtrabbitCode.Inventor.Attributes;component/Resources/Styles/Theme.Light.xaml" />
                <ResourceDictionary Source="/ExtrabbitCode.Inventor.Attributes;component/Resources/Styles/Theme.Dark.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="SettingsRowBackgroundBrush" Color="#3A3A3A" />
            <SolidColorBrush x:Key="SettingsRowBorderBrush" Color="#505050" />

            <SolidColorBrush x:Key="ListItemBackgroundBrush" Color="#323232" />
            <SolidColorBrush x:Key="ListItemBorderBrush" Color="#505050" />
            <SolidColorBrush x:Key="ListItemHoverBrush" Color="#404040" />
            <SolidColorBrush x:Key="ListItemUnderlineBrush" Color="#B9DDED" />

            <Style
                x:Key="AttributeSetListBoxItemStyle"
                TargetType="ListBoxItem">
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="Margin" Value="0,0,0,6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter
                    Property="Background"
                    Value="{StaticResource ListItemBackgroundBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter
                    Property="BorderBrush"
                    Value="{StaticResource ListItemBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Grid>
                                <Border
                                    x:Name="ItemBorder"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6"
                                    SnapsToDevicePixels="True">
                                    <ContentPresenter
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                </Border>

                                <Border
                                    x:Name="SelectionUnderline"
                                    Height="2"
                                    Margin="8,0,8,4"
                                    VerticalAlignment="Bottom"
                                    Background="Transparent"
                                    CornerRadius="2" />
                            </Grid>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter
                                        TargetName="ItemBorder"
                                        Property="Background"
                                        Value="{StaticResource ListItemHoverBrush}" />
                                </Trigger>

                                <Trigger Property="IsSelected" Value="True">
                                    <Setter
                                        TargetName="SelectionUnderline"
                                        Property="Background"
                                        Value="{StaticResource ListItemUnderlineBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style
                x:Key="SectionTitleTextStyle"
                TargetType="TextBlock">
                <Setter Property="Margin" Value="0,0,0,12" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style
                x:Key="SettingsRowBorderStyle"
                TargetType="Border">
                <Setter Property="Margin" Value="0,0,0,8" />
                <Setter Property="Padding" Value="12" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter
                    Property="Background"
                    Value="{StaticResource SettingsRowBackgroundBrush}" />
                <Setter
                    Property="BorderBrush"
                    Value="{StaticResource SettingsRowBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="Settings"
            CanMaximize="False"
            ShowMaximize="False"
            ShowMinimize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon
                    Source="pack://application:,,,/ExtrabbitCode.Inventor.Attributes;component/Resources/appIcon.png" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <ScrollViewer
            Grid.Row="2"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ui:Card Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            FontFamily="{DynamicResource InvFontFamily}"
                            FontSize="{DynamicResource InvFontSizeNormal}"
                            Text="General" />

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Text="Show confirmation messages" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Opacity="0.8"
                                        Text="Globally enable or disable confirmation dialogs for destructive actions." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding ShowConfirmationMessages, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Text="Single attribute delete warning" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Opacity="0.8"
                                        Text="Show a confirmation before deleting selected attribute data." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding ShowWarningOnSingleAttributeDelete, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Text="Delete all attributes warning" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Opacity="0.8"
                                        Text="Show a confirmation before deleting all attributes." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding ShowWarningOnDeleteAllAttributes, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Text="Update on document switch" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Opacity="0.8"
                                        Text="Reload attributes automatically when the active document changes." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding UpdateAttributesOnDocumentSwitch, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Text="Delete Autodesk default attribute sets" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Opacity="0.8"
                                        Text="Allows Delete All to remove Autodesk/internal attribute sets." />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        FontFamily="{DynamicResource InvFontFamily}"
                                        FontSize="{DynamicResource InvFontSizeNormal}"
                                        Foreground="Orange"
                                        FontWeight="SemiBold"
                                        Text="Warning: This can destroy internal iLogic rules and other Autodesk-managed data." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding DeleteAutodeskDefaultAttributeSets, Mode=TwoWay}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ui:Card>

                <ui:Card>
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            FontFamily="{DynamicResource InvFontFamily}"
                            FontSize="{DynamicResource InvFontSizeNormal}"
                            Text="Attribute Set Name Library" />

                        <TextBlock
                            Margin="0,0,0,8"
                            Opacity="0.8"
                            FontFamily="{DynamicResource InvFontFamily}"
                            FontSize="{DynamicResource InvFontSizeNormal}"
                            Text="Manage reusable attribute set names shown in the Add Attribute dialog." />

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                                <RowDefinition></RowDefinition>
                            </Grid.RowDefinitions>

                            <TextBox
                                Grid.Column="0"
                                FontFamily="{DynamicResource InvFontFamily}"
                                FontSize="{DynamicResource InvFontSizeNormal}"
                                Text="{Binding NewAttributeSetName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />
                            <ui:Button
                                Grid.Row="0" Grid.Column="2"
                                FontFamily="{DynamicResource InvFontFamily}"
                                FontSize="{DynamicResource InvFontSizeNormal}"
                                Command="{Binding AddAttributeSetNameCommand}"
                                Content="Add"
                                IsEnabled="{Binding CanAddAttributeSetName}"/>

                            <ScrollViewer
                                Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                                <ListBox
                                    MinHeight="50"
                                    MaxHeight="400"
                                    Background="Transparent"
                                    BorderThickness="1"
                                    FontFamily="{DynamicResource InvFontFamily}"
                                    FontSize="{DynamicResource InvFontSizeNormal}"
                                    ItemContainerStyle="{StaticResource AttributeSetListBoxItemStyle}"
                                    ItemsSource="{Binding AttributeSetNames}"
                                    SelectedItem="{Binding SelectedAttributeSetName, Mode=TwoWay}" />
                            </ScrollViewer>
                            <StackPanel
                                Grid.Row="2" Grid.Column="0" Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <ui:Button
                                    Appearance="Danger"
                                    FontFamily="{DynamicResource InvFontFamily}"
                                    FontSize="{DynamicResource InvFontSizeNormal}"
                                    Command="{Binding RemoveSelectedAttributeSetNameCommand}"
                                    Content="Remove Selected" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <ui:Card Grid.Row="1" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock
                    Style="{StaticResource SectionTitleTextStyle}"
                    FontFamily="{DynamicResource InvFontFamily}"
                    FontSize="{DynamicResource InvFontSizeNormal}"
                    Text="Privacy" />

                <Border Style="{StaticResource SettingsRowBorderStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock
                                FontWeight="SemiBold"
                                FontFamily="{DynamicResource InvFontFamily}"
                                FontSize="{DynamicResource InvFontSizeNormal}"
                                Text="Share anonymous usage statistics" />
                            <TextBlock
                                Margin="0,2,0,0"
                                FontFamily="{DynamicResource InvFontFamily}"
                                FontSize="{DynamicResource InvFontSizeNormal}"
                                Opacity="0.8"
                                TextWrapping="Wrap"
                                Text="Helps improve the add-in. Only command usage and version info are collected. No document names, file paths, or attribute values are sent." />
                        </StackPanel>

                        <CheckBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{Binding TelemetryEnabled, Mode=TwoWay}" />
                    </Grid>
                </Border>
            </StackPanel>
        </ui:Card>

        <StackPanel
            Grid.Row="4"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <ui:Button
                Width="100"
                Margin="0,0,8,0"
                FontFamily="{DynamicResource InvFontFamily}"
                FontSize="{DynamicResource InvFontSizeNormal}"
                Click="OkButton_OnClick"
                Content="OK"
                IsDefault="True" />

            <ui:Button
                Width="100"
                Click="CancelButton_OnClick"
                FontFamily="{DynamicResource InvFontFamily}"
                FontSize="{DynamicResource InvFontSizeNormal}"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>