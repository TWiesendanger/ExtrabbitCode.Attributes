<ui:FluentWindow
    x:Class="ExtrabbitCode.Inventor.Attributes.UI.Dialog.AttributeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Attributes"
    FontFamily="{DynamicResource InvFontFamily}"
    FontSize="{DynamicResource InvFontSizeNormal}"
    Background="{DynamicResource InvWindowBackgroundBrush}"
    Foreground="{DynamicResource InvForegroundBrush}"
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <ui:FluentWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/ExtrabbitCode.Inventor.Attributes;component/Resources/Styles/Theme.Shared.xaml" />
                <ResourceDictionary Source="/ExtrabbitCode.Inventor.Attributes;component/Resources/Styles/Theme.Light.xaml" />
                <ResourceDictionary Source="/ExtrabbitCode.Inventor.Attributes;component/Resources/Styles/Theme.Dark.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </ui:FluentWindow.Resources>

    <Grid Background="{DynamicResource InvWindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Margin="5"
            Padding="10"
            Grid.Row="0"
            Background="{DynamicResource InvToolbarBackgroundBrush}"
            BorderBrush="{DynamicResource InvToolbarBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource InvCornerRadius}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ui:Button
                    Grid.Column="0"
                    Width="{DynamicResource InvControlWidth}"
                    Height="{DynamicResource InvControlHeight}"
                    Background="{DynamicResource InvAccentBrush}"
                    Command="{Binding AddAttributeCommand}"
                    Icon="{ui:SymbolIcon Add24}"
                    Appearance="Transparent"
                    ToolTip="Add Attribute" />

                <ui:SplitButton
                    Grid.Column="2"
                    Width="80"
                    Height="{DynamicResource InvControlHeight}"
                    Appearance="Dark"
                    Command="{Binding DeleteSelectedCommand}"
                    Icon="{ui:SymbolIcon Delete24}"
                    ToolTip="Delete">
                    <ui:SplitButton.Flyout>
                        <ContextMenu
                            Background="{DynamicResource InvPanelBackgroundBrush}"
                            FontFamily="{DynamicResource InvFontFamily}"
                            FontSize="{DynamicResource InvFontSizeNormal}"
                            DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                            <MenuItem
                                Header="Delete Selection"
                                Command="{Binding DeleteSelectedCommand}" />
                            <MenuItem
                                Header="Delete All"
                                Command="{Binding DeleteAllCommand}" />
                        </ContextMenu>
                    </ui:SplitButton.Flyout>
                </ui:SplitButton>

                <ui:Button
                    Grid.Column="4"
                    Appearance="Transparent"
                    Width="{DynamicResource InvControlWidth}"
                    Height="{DynamicResource InvControlHeight}"
                    Command="{Binding GetAllAttributesCommand}"
                    Icon="{ui:SymbolIcon ArrowClockwise24}"
                    ToolTip="Refresh" />

                <ui:TextBox
                    Grid.Column="6"
                    VerticalAlignment="Center"
                    Height="{DynamicResource InvControlHeight}"
                    Icon="{ui:SymbolIcon Search12}"
                    IconPlacement="Right"
                    FontFamily="{DynamicResource InvFontFamily}"
                    FontSize="{DynamicResource InvFontSizeNormal}"
                    PlaceholderText="Search ..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Search attribute sets or attributes" />

                <ui:Button
                    Grid.Column="8"
                    Appearance="Transparent"
                    Width="{DynamicResource InvControlWidth}"
                    Height="{DynamicResource InvControlHeight}"
                    Command="{Binding OpenSettingsCommand}"
                    Icon="{ui:SymbolIcon Settings24}"
                    ToolTip="Settings" />
            </Grid>
        </Border>

        <Border
            Margin="5"
            Padding="10"
            Grid.Row="2"
            Background="{DynamicResource InvPanelBackgroundBrush}"
            BorderBrush="{DynamicResource InvPanelBorderBrush}"
            BorderThickness="1"
            CornerRadius="{DynamicResource InvCornerRadius}">
            <Grid>
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource InvMutedForegroundBrush}"
                    Opacity="0.7"
                    Text="Attribute tree goes here" />
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>