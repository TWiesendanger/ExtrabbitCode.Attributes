<Window
    x:Class="ExtrabbitCode.Attributes.UI.Dialog.InfoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Info ExtrabbitCode.Attributes"
    Width="1000"
    Height="520"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Icon="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/appIcon.png"
    mc:Ignorable="d">

    <Window.Resources>
        <Style
            x:Key="ElevatedCardStyle"
            TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background}" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Opacity="0.22" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12" TextElement.FontSize="13">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Style="{StaticResource ElevatedCardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Image
                    Grid.Column="0"
                    Width="72"
                    Height="72"
                    VerticalAlignment="Top"
                    Source="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/appIcon.png" />

                <StackPanel Grid.Column="2">
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="ExtrabbitCode.Attributes" />

                    <TextBlock
                        Margin="0,6,0,0"
                        Opacity="0.8"
                        Text="Manage and inspect Autodesk Inventor attributes and attribute sets." />

                    <TextBlock
                        Margin="0,10,0,0"
                        FontWeight="SemiBold"
                        Text="{Binding ProgramVersion, StringFormat=Version: {0}}" />
                </StackPanel>

                <Image
                    Grid.Column="3"
                    Width="250"
                    Height="72"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Source="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/extrabbit.png" />
            </Grid>
        </Border>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal">
            <Button
                Width="150"
                Margin="0,0,8,0"
                Command="{Binding OpenDocumentationCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE736;" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Documentation" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button
                Width="180"
                Margin="0,0,8,0"
                Command="{Binding OpenGitHubCommand}">
                <StackPanel Orientation="Horizontal">
                    <Viewbox Width="16" Height="16" Margin="0,0,8,0" VerticalAlignment="Center">
                        <Path Fill="{DynamicResource Brush.Foreground}"
                              Data="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                    </Viewbox>
                    <TextBlock Text="GitHub Repository" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button
                Width="150"
                Command="{Binding OpenAutodeskStoreCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8A7;" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Autodesk Store" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Border
            Grid.Row="4"
            Style="{StaticResource ElevatedCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Version History" />

                <TextBox
                    Grid.Row="2"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    VerticalContentAlignment="Top"
                    Text="{Binding VersionHistory}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <StackPanel
            Grid.Row="6"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Click="CloseButton_OnClick"
                Content="Close"
                IsDefault="True"
                Style="{DynamicResource AccentButton}" />
        </StackPanel>
    </Grid>
</Window>
