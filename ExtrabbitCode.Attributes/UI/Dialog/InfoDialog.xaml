<Window
    x:Class="ExtrabbitCode.Attributes.UI.Dialog.InfoDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Info ExtrabbitCode.Attributes"
    Width="1000"
    Height="520"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    Icon="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/appIcon.png"
    mc:Ignorable="d">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="16"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius.Card}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Image
                    Grid.Column="0"
                    Width="72"
                    Height="72"
                    VerticalAlignment="Top"
                    Source="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/appIcon.png" />

                <StackPanel Grid.Column="2">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="ExtrabbitCode.Attributes" />

                    <TextBlock
                        Margin="0,6,0,0"
                        Opacity="0.8"
                        Text="Manage and inspect Autodesk Inventor attributes and attribute sets." />

                    <TextBlock
                        Margin="0,10,0,0"
                        FontWeight="SemiBold"
                        Text="{Binding ProgramVersion, StringFormat=Version: {0}}" />
                </StackPanel>

                <Image
                    Grid.Column="3"
                    Width="250"
                    Height="72"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Source="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/extrabbit.png" />
            </Grid>
        </Border>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal">
            <Button
                Width="150"
                Margin="0,0,8,0"
                Command="{Binding OpenDocumentationCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE736;" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Documentation" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button
                Width="180"
                Margin="0,0,8,0"
                Command="{Binding OpenGitHubCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8A7;" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="GitHub Repository" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <Button
                Width="150"
                Command="{Binding OpenAutodeskStoreCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" Text="&#xE8A7;" Margin="0,0,8,0" VerticalAlignment="Center" />
                    <TextBlock Text="Autodesk Store" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Border
            Grid.Row="4"
            Padding="12"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius.Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    FontSize="14"
                    FontWeight="SemiBold"
                    Text="Version History" />

                <TextBox
                    Grid.Row="2"
                    AcceptsReturn="True"
                    IsReadOnly="True"
                    Text="{Binding VersionHistory}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Border>

        <StackPanel
            Grid.Row="6"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Click="CloseButton_OnClick"
                Content="Close"
                IsDefault="True"
                Style="{DynamicResource AccentButton}" />
        </StackPanel>
    </Grid>
</Window>
