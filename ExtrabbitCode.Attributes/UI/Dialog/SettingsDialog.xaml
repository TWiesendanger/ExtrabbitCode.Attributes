<Window
    x:Class="ExtrabbitCode.Attributes.UI.Dialog.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Settings"
    Width="900"
    Height="650"
    MinWidth="800"
    MinHeight="500"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Icon="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/appIcon.png"
    mc:Ignorable="d">

    <Window.Resources>
        <Style
            x:Key="AttributeSetListBoxItemStyle"
            TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource Brush.Panel}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Foreground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid>
                            <Border
                                x:Name="ItemBorder"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                            </Border>

                            <Border
                                x:Name="SelectionUnderline"
                                Height="2"
                                Margin="8,0,8,4"
                                VerticalAlignment="Bottom"
                                Background="Transparent"
                                CornerRadius="2" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter
                                    TargetName="ItemBorder"
                                    Property="Background"
                                    Value="{DynamicResource Brush.AccentMuted}" />
                            </Trigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter
                                    TargetName="SelectionUnderline"
                                    Property="Background"
                                    Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="SectionTitleTextStyle"
            TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style
            x:Key="SettingsRowBorderStyle"
            TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Brush.Control}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style
            x:Key="SettingsSectionCardStyle"
            TargetType="Border">
            <Setter Property="Margin" Value="2,2,2,16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background}" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Opacity="0.22" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16" TextElement.FontSize="13">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource SettingsSectionCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="General" />

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Show confirmation messages" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Opacity="0.8"
                                        Text="Globally enable or disable confirmation dialogs for destructive actions." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding ShowConfirmationMessages, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Single attribute delete warning" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Opacity="0.8"
                                        Text="Show a confirmation before deleting selected attribute data." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding ShowWarningOnSingleAttributeDelete, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Delete all attributes warning" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Opacity="0.8"
                                        Text="Show a confirmation before deleting all attributes." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding ShowWarningOnDeleteAllAttributes, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Update on document switch" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Opacity="0.8"
                                        Text="Reload attributes automatically when the active document changes." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding UpdateAttributesOnDocumentSwitch, Mode=TwoWay}" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Delete Autodesk default attribute sets" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Opacity="0.8"
                                        Text="Allows Delete All to remove Autodesk/internal attribute sets." />
                                    <TextBlock
                                        Margin="0,6,0,0"
                                        Foreground="Orange"
                                        FontWeight="SemiBold"
                                        Text="Warning: This can destroy internal iLogic rules and other Autodesk-managed data." />
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding DeleteAutodeskDefaultAttributeSets, Mode=TwoWay}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSectionCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="Privacy" />

                        <Border Style="{StaticResource SettingsRowBorderStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="Share anonymous usage statistics" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        Opacity="0.8"
                                        TextWrapping="Wrap"
                                        Text="Helps improve the add-in. Only command usage and version info are collected. No document names, file paths, or attribute values are sent." />
                                    <TextBlock Margin="0,4,0,0">
                                        <Hyperlink
                                            NavigateUri="https://attributes.extrabbitcode.com/docs/privacy"
                                            RequestNavigate="TelemetryLink_OnRequestNavigate">Privacy policy</Hyperlink>
                                    </TextBlock>
                                </StackPanel>

                                <CheckBox
                                    Grid.Column="1"
                                    VerticalAlignment="Center"
                                    IsChecked="{Binding TelemetryEnabled, Mode=TwoWay}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource SettingsSectionCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Style="{StaticResource SectionTitleTextStyle}"
                            Text="Attribute Set Name Library" />

                        <TextBlock
                            Margin="0,0,0,8"
                            Opacity="0.8"
                            Text="Manage reusable attribute set names shown in the Add Attribute dialog." />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBox
                                Grid.Row="0" Grid.Column="0"
                                VerticalAlignment="Center"
                                Text="{Binding NewAttributeSetName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=False}" />
                            <Button
                                Grid.Row="0" Grid.Column="2"
                                VerticalAlignment="Center"
                                Command="{Binding AddAttributeSetNameCommand}"
                                Content="Add"
                                IsEnabled="{Binding CanAddAttributeSetName}" />

                            <ListBox
                                Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                Margin="0,10,0,0"
                                MinHeight="120"
                                Padding="4"
                                Background="Transparent"
                                BorderThickness="0"
                                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                ItemContainerStyle="{StaticResource AttributeSetListBoxItemStyle}"
                                ItemsSource="{Binding AttributeSetNames}"
                                SelectedItem="{Binding SelectedAttributeSetName, Mode=TwoWay}" />

                            <StackPanel
                                Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                                <Button
                                    Command="{Binding RemoveSelectedAttributeSetNameCommand}"
                                    Content="Remove Selected"
                                    Style="{DynamicResource DangerButton}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Width="100"
                Margin="0,0,8,0"
                Click="OkButton_OnClick"
                Content="OK"
                IsDefault="True"
                Style="{DynamicResource AccentButton}" />

            <Button
                Width="100"
                Click="CancelButton_OnClick"
                Content="Cancel"
                IsCancel="True" />
        </StackPanel>
    </Grid>
</Window>
