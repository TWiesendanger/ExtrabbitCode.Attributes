<Window
    x:Class="ExtrabbitCode.Attributes.UI.Dialog.AddAttributeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding DialogTitle}"
    Width="500"
    Height="360"
    MinWidth="500"
    MaxWidth="500"
    MinHeight="360"
    MaxHeight="360"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Icon="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/addAttribute_Dialog.png"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Padding="16"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius.Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Attribute Set Name" />

                <ComboBox
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalContentAlignment="Center"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding CanEditAttributeSetName}"
                    IsEditable="True"
                    IsTextSearchEnabled="True"
                    ItemsSource="{Binding AttributeSetNameLibrary}"
                    StaysOpenOnEdit="True"
                    Text="{Binding AttributeSetName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, Mode=TwoWay}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Attribute Name" />

                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding CanEditAttributeName}"
                    Text="{Binding AttributeName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Value Type" />

                <ComboBox
                    Grid.Row="4"
                    Grid.Column="1"
                    IsEnabled="{Binding CanEditValueType}"
                    VerticalAlignment="Center"
                    ItemsSource="{Binding ValueTypes}"
                    SelectedItem="{Binding SelectedValueType}" />

                <TextBlock
                    Grid.Row="6"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Value" />

                <Grid Grid.Row="6" Grid.Column="1">
                    <TextBox
                        VerticalAlignment="Center"
                        Text="{Binding AttributeValue, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                        Visibility="{Binding IsTextValueType, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <ComboBox
                        VerticalAlignment="Center"
                        ItemsSource="{Binding BooleanValues}"
                        SelectedItem="{Binding SelectedBooleanValue, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsBooleanType, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Padding="10"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius.Card}">
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button
                    x:Name="OkButton"
                    Width="125"
                    Margin="0,0,8,0"
                    Content="OK"
                    IsDefault="True"
                    IsEnabled="{Binding CanSubmit}"
                    Command="{Binding AddAttributeCommand}"
                    Style="{DynamicResource AccentButton}" />

                <Button
                    x:Name="CancelButton"
                    Width="125"
                    Content="Cancel"
                    IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
