<Window
    x:Class="ExtrabbitCode.Attributes.UI.Dialog.AddAttributeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="{Binding DialogTitle}"
    Width="560"
    Height="340"
    MinWidth="560"
    MaxWidth="560"
    MinHeight="340"
    MaxHeight="340"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    WindowStartupLocation="CenterOwner"
    Icon="pack://application:,,,/ExtrabbitCode.Attributes;component/Resources/addAttribute_Dialog.png"
    mc:Ignorable="d">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- Elevated card: same surface as the dialog, defined by a soft drop shadow instead of a
             flat grey panel (matches the Settings/Info dialogs). -->
        <Style x:Key="ElevatedCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Background" Value="{DynamicResource Brush.Background}" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="1" Direction="270" Opacity="0.22" Color="#000000" />
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12" TextElement.FontSize="13">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Margin="2,2,2,4"
            Style="{StaticResource ElevatedCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="18" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Attribute Set Name" />

                <ComboBox
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalContentAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="13"
                    IsEnabled="{Binding CanEditAttributeSetName}"
                    IsEditable="True"
                    IsTextSearchEnabled="True"
                    ItemsSource="{Binding AttributeSetNameLibrary}"
                    StaysOpenOnEdit="True"
                    Text="{Binding AttributeSetName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True, Mode=TwoWay}" />

                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Attribute Name" />

                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="13"
                    Padding="4,4"
                    IsEnabled="{Binding CanEditAttributeName}"
                    Text="{Binding AttributeName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}" />

                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Value Type" />

                <ComboBox
                    Grid.Row="4"
                    Grid.Column="1"
                    IsEnabled="{Binding CanEditValueType}"
                    VerticalAlignment="Center"
                    VerticalContentAlignment="Center"
                    FontSize="13"
                    ItemsSource="{Binding ValueTypes}"
                    SelectedItem="{Binding SelectedValueType}" />

                <TextBlock
                    Grid.Row="6"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Value" />

                <Grid Grid.Row="6" Grid.Column="1">
                    <TextBox
                        VerticalAlignment="Center"
                        FontSize="13"
                        Padding="4,4"
                        Text="{Binding AttributeValue, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                        Visibility="{Binding IsTextValueType, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <ComboBox
                        VerticalAlignment="Center"
                        VerticalContentAlignment="Center"
                        FontSize="13"
                        ItemsSource="{Binding BooleanValues}"
                        SelectedItem="{Binding SelectedBooleanValue, UpdateSourceTrigger=PropertyChanged}"
                        Visibility="{Binding IsBooleanType, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Margin="2,4,2,2"
            Padding="10"
            Style="{StaticResource ElevatedCardStyle}">
            <StackPanel
                HorizontalAlignment="Right"
                Orientation="Horizontal">

                <Button
                    x:Name="OkButton"
                    Width="125"
                    Margin="0,0,8,0"
                    FontSize="13"
                    Content="OK"
                    IsDefault="True"
                    IsEnabled="{Binding CanSubmit}"
                    Command="{Binding AddAttributeCommand}"
                    Style="{DynamicResource AccentButton}" />

                <Button
                    x:Name="CancelButton"
                    Width="125"
                    FontSize="13"
                    Content="Cancel"
                    IsCancel="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
