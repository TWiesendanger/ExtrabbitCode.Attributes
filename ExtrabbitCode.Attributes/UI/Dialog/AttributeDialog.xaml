<Window
    x:Class="ExtrabbitCode.Attributes.UI.Dialog.AttributeDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uiModels="clr-namespace:ExtrabbitCode.Attributes.Models"
    xmlns:converter="clr-namespace:ExtrabbitCode.Attributes.Helper.Converter"
    xmlns:behaviors="clr-namespace:ExtrabbitCode.Attributes.Helper.Behavior"
    Title="Attributes"
    d:DesignHeight="600"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <Window.Resources>
        <converter:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="2" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="5"
            Grid.Row="0"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius.Control}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Grid.Column="0"
                    Width="40" Height="30"
                    Style="{DynamicResource IconButton}"
                    Command="{Binding AddAttributeCommand}"
                    ToolTip="Add Attribute">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Text="&#xE710;" />
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button
                        Width="40" Height="30"
                        Style="{DynamicResource IconButton}"
                        Command="{Binding DeleteSelectedCommand}"
                        ToolTip="Delete attributes on selected objects">
                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Text="&#xE74D;" />
                    </Button>
                    <Button
                        Width="40" Height="30"
                        Margin="4,0,0,0"
                        Style="{DynamicResource IconButton}"
                        Command="{Binding DeleteAllCommand}"
                        ToolTip="Delete all attributes in document">
                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Text="&#xE894;" />
                    </Button>
                </StackPanel>

                <Button
                    Grid.Column="4"
                    Width="40" Height="30"
                    Style="{DynamicResource IconButton}"
                    Command="{Binding GetAllAttributesCommand}"
                    ToolTip="Refresh">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Text="&#xE72C;" />
                </Button>

                <Button
                    Grid.Column="6"
                    Width="40" Height="30"
                    Style="{DynamicResource IconButton}"
                    Command="{Binding ExpandAllNodesCommand}"
                    ToolTip="Expand all">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Text="&#xE70D;" />
                </Button>

                <Button
                    Grid.Column="8"
                    Width="40" Height="30"
                    Style="{DynamicResource IconButton}"
                    Command="{Binding CollapseAllNodesCommand}"
                    ToolTip="Collapse all">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Text="&#xE70E;" />
                </Button>

                <Button
                    Grid.Column="10"
                    Width="40" Height="30"
                    Style="{DynamicResource IconButton}"
                    Command="{Binding PurgeAllOrphansCommand}"
                    ToolTip="Purge all orphaned attribute sets">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Text="&#xE75C;" />
                </Button>

                <TextBox
                    Grid.Column="12"
                    VerticalAlignment="Center"
                    Height="30"
                    Style="{DynamicResource SearchBox}"
                    Tag="Search ..."
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    ToolTip="Search attribute sets or attributes" />

                <Button
                    Grid.Column="14"
                    Width="40" Height="30"
                    Style="{DynamicResource IconButton}"
                    Command="{Binding OpenSettingsCommand}"
                    ToolTip="Settings">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Text="&#xE713;" />
                </Button>
            </Grid>
        </Border>

        <Border
            Grid.Row="2"
            Background="{DynamicResource Brush.Panel}"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource Radius.Control}">
            <Grid>
                <TreeView
                    x:Name="AttributeTreeView"
                    Margin="4"
                    Tag="{Binding}"
                    Background="Transparent"
                    BorderThickness="0"
                    Foreground="{DynamicResource Brush.Foreground}"
                    ItemsSource="{Binding AttributeTree}"
                    behaviors:TreeViewExpandStateBehavior.PreserveExpandState="True">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate
                            DataType="{x:Type uiModels:AttributeTreeNode}"
                            ItemsSource="{Binding Children}">
                            <Grid Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}">
                                <Grid.Style>
                                    <Style TargetType="Grid">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                <Setter Property="Background" Value="#4400AAFF" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ContextMenu>
                                    <ContextMenu
                                        DataContext="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource Self}}"
                                        Tag="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                        <MenuItem
                                            Header="Select in Window"
                                            Command="{Binding SelectNodeObjectCommand}"
                                            CommandParameter="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem
                                            Header="Edit"
                                            Visibility="{Binding Tag.CanEdit, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BooleanToVisibilityConverter}}"
                                            Command="{Binding EditNodeCommand}"
                                            CommandParameter="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                        <MenuItem
                                            Header="Delete"
                                            Command="{Binding DeleteNodeCommand}"
                                            CommandParameter="{Binding Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    </ContextMenu>
                                </Grid.ContextMenu>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Image
                                    Grid.Column="0"
                                    Width="16"
                                    Height="16"
                                    Margin="0,2,6,0"
                                    VerticalAlignment="Top"
                                    Source="{Binding IconSource}"
                                    Visibility="{Binding IconSource, Converter={StaticResource NullToVisibilityConverter}}" />

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Name}" />
                                    <TextBlock
                                        Margin="6,0,0,0"
                                        Foreground="{DynamicResource Brush.ForegroundMuted}"
                                        Text="{Binding Value}" />
                                </StackPanel>

                                <Button
                                    Grid.Column="2"
                                    Width="20"
                                    Height="20"
                                    Margin="6,0,0,0"
                                    Padding="0"
                                    VerticalAlignment="Top"
                                    Style="{DynamicResource IconButton}"
                                    Command="{Binding Tag.CopyNodeValueCommand, RelativeSource={RelativeSource AncestorType=Grid}}"
                                    CommandParameter="{Binding}"
                                    ToolTip="Copy value"
                                    Visibility="{Binding CanCopyValue, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13" Text="&#xE8C8;" />
                                </Button>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                </TreeView>
            </Grid>
        </Border>
    </Grid>
</Window>
